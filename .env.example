# DeceptiScope v2 — Environment Variables
# Copy to .env and fill in your API keys

# ── Frontier Model API Keys ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://deceptiscope:deceptiscope@localhost:5432/deceptiscope

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Model Paths ───────────────────────────────────────────────────────────
SHADOW_MODEL_PATH=./models/shadow
HF_HOME=./models/hf_cache

# ── Shadow Model Config ───────────────────────────────────────────────────
SHADOW_BASE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
SHADOW_LORA_RANK=16
SHADOW_TARGET_FIDELITY=0.85

# ── Evaluation ────────────────────────────────────────────────────────────
EVAL_SAMPLE_SIZE=100
EVAL_OUTPUT_DIR=./eval_results

# ── Frontend ──────────────────────────────────────────────────────────────
REACT_APP_WS_URL=ws://localhost:8000
